# The same source file (calculator_modes_test.py) belongs to two targets,
# each running it under a different CALC_MODE. Both show up as separate
# selectors, so bktec splits them independently.
py_test(
    name = "calculator_modes_int_test",
    srcs = [
        "calculator_modes_test.py",
        "//:conftest.py",
        "//tools:pytest_main.py",
    ],
    args = ["$(location :calculator_modes_test.py)"],
    env = {
        "CALC_MODE": "int",
        "TEST_SELECTOR_PRIMARY": "//calculator:calculator_modes_int_test",
    },
    imports = [".."],
    main = "//tools:pytest_main.py",
    deps = [
        ":calculator",
        "@pip//pytest",
    ],
)

