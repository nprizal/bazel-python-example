load("@rules_python//python:defs.bzl", "py_library", "py_test")

py_library(
    name = "calculator",
    srcs = ["calculator.py"],
    # Imports are resolved relative to the repo root, so test modules can
    # do `from calculator import calculator`.
    imports = [".."],
    visibility = ["//visibility:public"],
)

py_test(
    name = "calculator_test",
    srcs = [
        "calculator_test.py",
        "//:conftest.py",
        "//tools:pytest_main.py",
    ],
    args = ["$(location :calculator_test.py)"],
    env = {"TEST_SELECTOR_PRIMARY": "//calculator:calculator_test"},
    imports = [".."],
    main = "//tools:pytest_main.py",
    deps = [
        ":calculator",
        "@pip//pytest",
    ],
)

